{
  "name": "@promobase/sdk-runtime",
  "version": "0.2.1",
  "description": "Shared runtime primitives for @promobase ad platform SDKs — fetch-based HttpClient, cursor pagination, rate limiter, retry.",
  "keywords": [
    "sdk-runtime",
    "fetch",
    "http-client",
    "pagination",
    "rate-limit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/promobase/ad-platform-sdks",
    "directory": "packages/sdk-runtime"
  },
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
