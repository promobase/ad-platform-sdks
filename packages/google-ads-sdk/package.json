{
  "name": "@promobase/google-ads-sdk",
  "version": "0.1.1",
  "description": "Type-safe Google Ads API v23 SDK, runtime-agnostic, generated from protobuf. Customer-bound factory and typed GAQL query builder.",
  "keywords": [
    "google-ads",
    "google-ads-api",
    "google-ads-sdk",
    "google",
    "ads",
    "advertising",
    "marketing-api",
    "sdk",
    "typescript",
    "type-safe",
    "typed",
    "protobuf",
    "gaql",
    "campaign",
    "ad-group",
    "business-sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/promobase/ad-platform-sdks",
    "directory": "packages/google-ads-sdk"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./v23": {
      "bun": "./dist/generated/v23/index.js",
      "types": "./dist/generated/v23/index.d.ts",
      "import": "./dist/generated/v23/index.js",
      "default": "./dist/generated/v23/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "codegen": "bun run src/codegen/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/",
    "prepublishOnly": "bun run clean && bun run build",
    "prepack": "node ../../scripts/publish-manifest.mjs prepare",
    "postpack": "node ../../scripts/publish-manifest.mjs restore"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@promobase/sdk-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "protobufjs": "^7.4.0",
    "typescript": "^5.6.0"
  },
  "module": "./dist/index.js",
  "engines": {
    "node": ">=18"
  }
}
