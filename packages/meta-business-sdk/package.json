{
  "name": "@promobase/meta-business-sdk-ts",
  "version": "0.0.3",
  "description": "Type-safe TypeScript SDK for the Meta (Facebook) Marketing API — fully typed Graph API client with auto-generated types for 994 API objects",
  "keywords": [
    "meta",
    "facebook",
    "meta-business-sdk",
    "facebook-business-sdk",
    "facebook-ads",
    "meta-ads",
    "facebook-marketing-api",
    "meta-marketing-api",
    "graph-api",
    "facebook-graph-api",
    "typescript",
    "type-safe",
    "typed",
    "codegen",
    "ads",
    "advertising",
    "ad-account",
    "campaign",
    "adset",
    "sdk",
    "api-client",
    "business-sdk",
    "facebook-nodejs-business-sdk",
    "facebook-business-sdk-codegen"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/promobase/ad-platform-sdks",
    "directory": "packages/meta-business-sdk"
  },
  "module": "./dist/generated/index.js",
  "main": "./dist/generated/index.js",
  "types": "./dist/generated/index.d.ts",
  "type": "module",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "codegen": "bun src/codegen/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@promobase/sdk-runtime": "^0.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "ai": "^6.0.158",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "exports": {
    ".": {
      "bun": "./dist/generated/index.js",
      "types": "./dist/generated/index.d.ts",
      "import": "./dist/generated/index.js",
      "default": "./dist/generated/index.js"
    },
    "./ai": {
      "bun": "./dist/ai/index.js",
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.js",
      "default": "./dist/ai/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
