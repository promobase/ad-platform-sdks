{
  "name": "@promobase/ad-platforms",
  "version": "0.1.1",
  "description": "Unified type-safe TypeScript SDK for Meta (Facebook, Instagram, Threads), TikTok, and future ad platforms — single install, single namespace",
  "keywords": [
    "meta",
    "facebook",
    "instagram",
    "threads",
    "tiktok",
    "tiktok-business",
    "google-ads",
    "ads",
    "advertising",
    "marketing-api",
    "typescript",
    "type-safe",
    "sdk",
    "ad-platforms",
    "business-sdk",
    "ai-sdk",
    "llm-tools"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/promobase/ad-platform-sdks",
    "directory": "packages/ad-platforms"
  },
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@promobase/meta-business-sdk-ts": "^0.0.3",
    "@promobase/tiktok-business-sdk": "^0.0.3",
    "@promobase/google-ads-sdk": "^0.1.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3",
    "ai": "^6.0.0",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./ai": {
      "bun": "./dist/unified-tools.js",
      "types": "./dist/unified-tools.d.ts",
      "import": "./dist/unified-tools.js",
      "default": "./dist/unified-tools.js"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
