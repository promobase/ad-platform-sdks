{
  "name": "@promobase/tiktok-business-sdk",
  "version": "0.0.1",
  "description": "Type-safe TypeScript SDK for the TikTok Business API — OAuth, video/photo publishing, comments, and account insights",
  "keywords": [
    "tiktok", "tiktok-business-api", "tiktok-ads", "tiktok-marketing-api",
    "tiktok-sdk", "tiktok-api",
    "typescript", "type-safe", "typed",
    "sdk", "api-client", "business-sdk",
    "video-publish", "content-api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/promobase/ad-platform-sdks",
    "directory": "packages/tiktok-business-sdk"
  },
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "files": [
    "src/**/*.ts",
    "README.md"
  ],
  "scripts": {
    "codegen": "bun src/codegen/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@promobase/sdk-runtime": "workspace:*",
    "ai": "^6.0.158",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
