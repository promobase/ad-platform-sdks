{
  "name": "@promobase/tiktok-business-sdk",
  "version": "0.0.3",
  "description": "Type-safe TypeScript SDK for the TikTok Business API — OAuth, video/photo publishing, comments, and account insights",
  "keywords": [
    "tiktok",
    "tiktok-business-api",
    "tiktok-ads",
    "tiktok-marketing-api",
    "tiktok-sdk",
    "tiktok-api",
    "typescript",
    "type-safe",
    "typed",
    "sdk",
    "api-client",
    "business-sdk",
    "video-publish",
    "content-api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/promobase/ad-platform-sdks",
    "directory": "packages/tiktok-business-sdk"
  },
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "codegen": "bun src/codegen/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "[ -d tests ] && bun test tests/ || echo 'no tests'",
    "prepublishOnly": "bun run clean && bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@promobase/sdk-runtime": "workspace:*",
    "ai": "^6.0.158",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
