{
  "name": "@promobase/linkedin-sdk",
  "version": "0.1.0",
  "description": "Type-safe TypeScript SDK for LinkedIn organic publishing and OAuth",
  "keywords": [
    "linkedin",
    "linkedin-api",
    "marketing-api",
    "social-media",
    "publishing",
    "typescript",
    "type-safe",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/promobase/ad-platform-sdks",
    "directory": "packages/linkedin-sdk"
  },
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist/**/*",
    "src/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests/",
    "prepublishOnly": "bun run clean && bun run build",
    "prepack": "node ../../scripts/publish-manifest.mjs prepare",
    "postpack": "node ../../scripts/publish-manifest.mjs restore"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
