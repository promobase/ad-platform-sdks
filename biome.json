{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.json",
      "!**/dist",
      "!**/node_modules",
      "!**/vendor",
      "!**/generated",
      "!**/api_specs",
      "!fern/openapi",
      "!google-discovery",
      "!**/.changeset",
      "!**/*.tsbuildinfo"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off",
        "noConfusingVoidType": "off",
        "noTemplateCurlyInString": "off",
        "noAssignInExpressions": "off",
        "noDoubleEquals": "warn"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "warn",
        "useTemplate": "off",
        "useNodejsImportProtocol": "warn",
        "useExponentiationOperator": "off"
      },
      "complexity": {
        "noBannedTypes": "off",
        "useLiteralKeys": "off",
        "noStaticOnlyClass": "off",
        "useOptionalChain": "warn",
        "useDateNow": "off",
        "noUselessLoneBlockStatements": "off"
      },
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedFunctionParameters": "off",
        "noUnusedImports": "warn",
        "useParseIntRadix": "warn",
        "noInnerDeclarations": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
